{
  "name": "ssoi-mgmt",
  "private": true,
  "version": "0.1.0",
  "description": "双十中学五大学科竞赛管理网站",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "setup": "npm install",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev --workspace backend\" \"npm:dev --workspace frontend\"",
    "build": "npm run build --workspace frontend",
    "start": "node backend/src/server.js",
    "import": "node scripts/import_xlsx.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
