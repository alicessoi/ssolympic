# Server
PORT=3001
NODE_ENV=development

# Database (relative to backend/)
DB_PATH=./data/ssoi.db

# Auth — required. JWT_SECRET must be a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=24h

# Default admin (auto-seeded on first server boot if user does not exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-on-first-login

# CORS — only used if you split origin. Leave empty for same-origin (recommended).
CORS_ORIGIN=
